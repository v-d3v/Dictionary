<Window x:Class="Dictionary.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Словарь английского языка" Height="600" Width="650"
        Background="#F0F4F8">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- Строка 0: поле ввода и кнопки -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox x:Name="WordInput"
                     Width="400" Height="38" FontSize="15"
                     Padding="8,6" VerticalContentAlignment="Center"
                     BorderBrush="#B0BEC5" BorderThickness="1"
                     KeyDown="WordInput_KeyDown"/>
            <Button Content="Найти"
                    Width="90" Height="38" Margin="10,0,0,0"
                    Background="#3498DB" Foreground="White"
                    FontSize="14" BorderThickness="0" Cursor="Hand"
                    Click="SearchButton_Click"/>
            <Button x:Name="PlayButton"
                    Content="🔊"
                    Width="42" Height="38" Margin="6,0,0,0"
                    Background="#27AE60" Foreground="White"
                    FontSize="16" BorderThickness="0" Cursor="Hand"
                    IsEnabled="False"
                    Click="PlayAudioButton_Click"/>
        </StackPanel>

        <!-- Строка 1: зона результатов с прокруткой -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ResultPanel"/>
        </ScrollViewer>

        <!-- Строка 2: статус внизу -->
        <TextBlock x:Name="StatusBar"
                   Grid.Row="2" Margin="0,8,0,0"
                   FontSize="12" Foreground="#7F8C8D"/>

        <!-- Строка 3: история поиска -->
        <StackPanel Grid.Row="3" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="История поиска:"
                           FontSize="12" Foreground="#7F8C8D"
                           VerticalAlignment="Center"/>
                <Button Content="Очистить"
                        Margin="10,0,0,0" Padding="6,2"
                        FontSize="11"
                        Background="#E74C3C" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="ClearHistory_Click"/>
            </StackPanel>
            <ListBox x:Name="HistoryList"
                     Height="80" FontSize="13"
                     BorderBrush="#B0BEC5"
                     MouseDoubleClick="HistoryList_MouseDoubleClick"/>
        </StackPanel>
    </Grid>
</Window>